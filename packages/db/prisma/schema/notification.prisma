enum NotificationScheduleType {
  IMMEDIATE
  SCHEDULED
  DELAYED
}

enum NotificationLanguage {
  en
  ar
  fr
}

enum NotificationType {
  GLOBAL
  GROUP
  PRIVATE
}

enum NotificationSourceType {
  CALENDAR
  TEACHER_COMMENT
  EXAM_SCHEDULE
  FEED
  HOMEWORK
  EXTRA_CURRICULAR
  FEES

  TIMETABLE // not sure bout this one
}

model Notification {
  id      String @id @default(uuid()) @db.Uuid
  title   Name?  @relation("NotificationTitle")
  content Name?  @relation("NotificationContent")

  type         NotificationType
  scheduleType NotificationScheduleType
  sourceId     String?
  sourceType   NotificationSourceType

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  role      UserRole?
  students Student[]

  // translations      NotificationTranslation[]
  userNotifications UserNotification[]

  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([schoolId, role])
}

model NotificationTranslation {
  id       String               @id @default(uuid()) @db.Uuid
  language NotificationLanguage

  title   String
  content String
  data    Json?

  // notificationId String       @db.Uuid
  // notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  // @@unique([notificationId, language])
}

model UserNotification {
  id String @id @default(uuid()) @db.Uuid

  notificationId String       @db.Uuid
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isRead Boolean @default(false)

  @@unique([userId, notificationId])
}
