enum NotificationScheduleType {
  IMMEDIATE
  SCHEDULED
  DELAYED
}

enum NotificationLanguage {
  en
  ar
  fr
}

enum NotificationType {
  MANUAL
  SYSTEM
}

enum NotificationContentType {
  TEACHER_COMMENT
  FEED
}


model Notification {
  id          String  @id @default(uuid()) @db.Uuid
  description String? @db.Text

  sourceId     String?
  scheduleType NotificationScheduleType
  type         NotificationType

  delaySeconds Int?
  scheduledAt  DateTime?

  translations           NotificationTranslation[]
  userNotifications       UserNotification[]

  createdById String  @db.Uuid
  createdBy   Account @relation("NotificationCreatedBy", fields: [createdById], references: [id])

  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


model NotificationTranslation {
  id       String               @id @default(uuid()) @db.Uuid
  language NotificationLanguage

  title   String
  content String
  data    Json?

  notificationId String       @db.Uuid
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, language])
}


model UserNotification {
  id String @id @default(uuid()) @db.Uuid

  notificationId String  @db.Uuid
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  userId String  @db.Uuid
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  isRead Boolean @default(false)


  @@unique([userId, notificationId])
}

