generator client {
  provider = "prisma-client"
  output   = "../../src/generated"
  moduleFormat = "esm"
  
  runtime = "nodejs"
}

datasource db {
  provider = "postgresql"
}





enum Gender {
  MALE
  FEMALE  
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}