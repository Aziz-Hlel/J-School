enum FeeItemStatus {
  PAID
  UNPAID
  PARTIALLY_PAID
}

model FeeItem {
  id String @id @default(uuid()) @db.Uuid

  title       String  @db.VarChar(255)
  description String? @db.Text
  amount      Float

  feeId String @db.Uuid
  fee   Fees   @relation(fields: [feeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status FeeItemStatus @default(UNPAID)

  payment Payment?

  @@map("feeItems")
}

enum PaymentMethod {
  CASH
  CREDIT
  CHEQUE
  TRANSFER
  OTHER
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid

  feeItemId String @db.Uuid @unique
  feeItem   FeeItem  @relation(fields: [feeItemId], references: [id], onDelete: Cascade)

  method    PaymentMethod @default(TRANSFER)
  reference String?
  date      DateTime?    @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Fees {
  id String @id @default(uuid()) @db.Uuid

  name String? @db.VarChar(255)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeItems FeeItem[]

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, studentId])
  @@map("fees")
}
