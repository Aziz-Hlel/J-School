
enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  EXPELLED
}


model StudentProfile {
  id String @id @db.Uuid 
  student Student @relation(fields: [id], references: [id], onDelete: Cascade)

  healthInfo String?
  vaccine    String?
  cpr        String?
  allergies  String?
  notes      String?

  emergencyContactName1 String?
  emergencyContactPhone1 String?
  emergencyContactRelation1 String?

  emergencyContactName2 String?
  emergencyContactPhone2 String?
  emergencyContactRelation2 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("student_profiles")
}


model Student {
  id String @id @default(uuid()) @db.Uuid
  uid String? @db.VarChar(50)

  firstName_ar String? @db.VarChar(255)
  lastName_ar String? @db.VarChar(255)
  firstName_en String? @db.VarChar(255)
  lastName_en String? @db.VarChar(255)

  dateOfBirth DateTime? @db.Date
  gender Gender
  status StudentStatus

  profile StudentProfile?
  parents StudentParents[]


  schoolId String @db.Uuid
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId String? @db.Uuid
  class Classroom? @relation(fields: [classId], references: [id], onDelete: Restrict)

  avatarId String? @db.Uuid
  avatar Media? @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  fees Fees[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([avatarId])
  @@unique([schoolId, uid])

  @@map("students")
}


model Parent{
  id String @id @default(uuid()) @db.Uuid

  emergencyPhone String? @db.VarChar(20)
 
  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  students StudentParents[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])

  @@map("parents")
}


model StudentParents {
  id String @id @default(uuid()) @db.Uuid

  parentId String @db.Uuid
  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  studentId String @db.Uuid
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId,studentId])

  @@map("student_parents")
}


model Teacher {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignments Assignment[]
  // sessions ClassSessions[] // * not so sure of
  // examSessions ExamSessions[] // * not so sure of
  // extraCurricularSessions ExtraCurricularSessions[] // * not so sure of

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])

  @@map("teachers")
}


