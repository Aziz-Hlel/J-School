enum StudentStatus {
  ACTIVE
  INACTIVE
  PENDING
  EXPELLED
}

enum VaccineStatus {
  NOT_VACCINATED
  PARTIALLY_VACCINATED
  FULLY_VACCINATED
}

model EmergencyContact {
  id String @id @default(uuid()) @db.Uuid

  name     String @db.VarChar(255)
  phone    String @db.VarChar(20)
  relation String @db.VarChar(255)

  profileId String         @db.Uuid
  profile   StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@map("emergency_contacts")
}

model StudentProfile {
  id      String  @id @db.Uuid
  student Student @relation(fields: [id], references: [id], onDelete: Cascade)

  healthInfo   String?
  vaccine      VaccineStatus
  allergies    String?
  notes        String?

  emergencyContacts EmergencyContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("student_profiles")
}

model Student {
  id  String  @id @default(uuid()) @db.Uuid
  uid String? @db.VarChar(50)

  firstName_ar String? @db.VarChar(255)
  lastName_ar  String? @db.VarChar(255)
  firstName_en String? @db.VarChar(255)
  lastName_en  String? @db.VarChar(255)

  dateOfBirth DateTime?     @db.Date
  gender      Gender
  status      StudentStatus

  profile StudentProfile?
  parents StudentParents[]

  attendances Attendance[]
  comments    TeacherComment[]
  aftercare   Aftercare[]
  homeworks   StudentHomework[]

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classroomId String?    @db.Uuid
  classroom   Classroom? @relation(fields: [classroomId], references: [id], onDelete: Restrict)

  avatarId String? @db.Uuid
  avatar   Media?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  fees                   Fees[]
  studentExtraCurricular StudentExtraCurricular[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([avatarId])
  @@unique([schoolId, uid])
  @@map("students")
}

model Parent {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  students StudentParents[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@map("parents")
}

model StudentParents {
  id String @id @default(uuid()) @db.Uuid

  parentId String @db.Uuid
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("student_parents")
}

model Teacher {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignments     Assignment[]
  extraCurricular ExtraCurricular[]
  comments        TeacherComment[]
  aftercare       Aftercare[]

  // sessions ClassSessions[] // * not so sure of
  // examSessions ExamSessions[] // * not so sure of
  // extraCurricularSessions ExtraCurricularSessions[] // * not so sure of
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@map("teachers")
}
